#shellcheck disable=SC2148,SC2155

if [ $MACHINE_OS == "Darwin" ]; then
    export KUBECONFIG=$(greadlink -f ./provision/kubeconfig)
    export ANSIBLE_CONFIG=$(greadlink -f ./ansible.cfg)
    export SOPS_AGE_KEY_FILE=$(greadlink -f ~/.config/sops/age/keys.txt)
else
    export KUBECONFIG=$(expand_path ./provision/kubeconfig)
    export ANSIBLE_CONFIG=$(expand_path ./ansible.cfg)
    export SOPS_AGE_KEY_FILE=$(expand_path ~/.config/sops/age/keys.txt)
fi
export ANSIBLE_HOST_KEY_CHECKING="False"
