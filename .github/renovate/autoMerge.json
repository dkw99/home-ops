{
  "packageRules": [
    {
      "matchDatasources": ["docker", "github-tags"],
      "automerge": true,
      "automergeType": "branch",
      "requiredStatusChecks": null,
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackageNames": [
        "homeassistant/home-assistant",
        "emqx/emqx",
        "ghcr.io/k8s-at-home/radarr",
        "ghcr.io/k8s-at-home/sonarr",
        "ghcr.io/k8s-at-home/nzbget",
        "plexinc/pms-docker",
        "hotio/readarr",
        "nodered/node-red",
        "zwavejs/zwavejs2mqtt",
        "renovatebot/github-action"
      ]
    },
    {
      "datasources": ["docker"],
      "automerge": true,
      "requiredStatusChecks": null,
      "schedule": "after 1am and before 5am",
      "updateTypes": ["minor", "patch"],
      "matchPackageNames": [
        "homeassistant/home-assistant",
        "emqx/emqx",
        "ghcr.io/k8s-at-home/radarr",
        "ghcr.io/k8s-at-home/sonarr",
        "ghcr.io/k8s-at-home/nzbget",
        "plexinc/pms-docker",
        "hotio/readarr",
        "nodered/node-red",
        "zwavejs/zwavejs2mqtt"
      ]
    },
    {
      "datasources": ["docker"],
      "automerge": true,
      "requiredStatusChecks": null,
      "schedule": ["before 3am on Monday"],
      "updateTypes": ["minor", "patch"],
      "matchPackageNames": [
        "ghcr.io/k8s-at-home/prowlarr",
        "ghcr.io/k8s-at-home/readarr"
      ]
    },
    {
      "datasources": ["helm"],
      "automerge": true,
      "requiredStatusChecks": null,
      "schedule": "after 1am and before 5am",
      "updateTypes": ["minor", "patch"],
      "matchPackageNames": ["thanos"]
    }
  ]
}
